# Daycare AI Platform — environment variable template
# Copy to .env and fill in. Never commit real values.

# ── Environment ───────────────────────────────────────
# "development" | "test" | "staging" | "production"
# In production: consent gate blocks (no dev bypass).
ENVIRONMENT=development

# ── Database ──────────────────────────────────────────
DATABASE_URL=postgresql://localhost/daycare_dev

# ── Twilio (WhatsApp ingress) ─────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# WhatsApp mode: "sandbox" for Twilio Sandbox (pilot), "production" for live number.
WHATSAPP_MODE=sandbox

# ── OpenAI ────────────────────────────────────────────
OPENAI_API_KEY=

# ── Resend (consent magic-link emails) ────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=Raina <onboarding@raina-pilot.com>

# ── App URLs ──────────────────────────────────────────
APP_BASE_URL=http://localhost:5173

# ── AWS S3 (photos) ───────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_S3_REGION=us-east-1

# ── Sentry ────────────────────────────────────────────
# Empty DSN = SDK init is a no-op. Set this when Sentry is provisioned.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0
